begin
  try
    try
      FLowInitApp := TLowInitApp.Create(lstCashSheet, 'CashSheet');
      Application.Initialize;
    except
      on e: Exception do
      begin
        Application.ProcessMessages;
        if not(e is ELowCancelException) then
        begin
          ShowMessage(Format(cMsgLowInitAppErr, [Application.Title, e.Message]));
        end;
      end;
    end;
  finally
    Application.ProcessMessages;
  end;

end.
