    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>WinCS</SanitizedProjectName>
        <PostBuildEvent><![CDATA["$(PROJECTDIR)\"PostBuild.bat $(Platform) "$(OUTPUTDIR)" $(OUTPUTNAME) $(OUTPUTEXT) $(Config) "$(PROJECTDIR)"
$(PostBuildEvent)]]></PostBuildEvent>
        <VerInfo_Build>4</VerInfo_Build>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
