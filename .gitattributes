# Set default behavior to automatically normalize line endings.
# * text=auto

# Force batch scripts to always use CRLF line endings so that if a repo is
# accessed in Windows via a file share from Linux, the scripts will work.
*.cmd text eol=crlf
*.bat text eol=crlf

# Handle merging special files
*.dpr       merge=main
*.dproj     merge=main
*.groupproj merge=main
*.skincfg   merge=main

forms/*MainMenu*.*  merge=main
UMenuControl.pas binary merge=ours

# restrict merging changes to these special files
#.gitignore merge=main
#.gitattributes merge=main
#.gitmodules merge=main
#.svn/ merge=main
#CODEOWNERS merge=main

